{
  "name": "planscribe-local",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "npm run build && node scripts/inline-dist.mjs",
    "package:release": "npm run build && node scripts/package-release.mjs",
    "package:release:ci": "npm run build && RELEASE_DIR_NAME=planscribe-local-release node scripts/package-release.mjs",
    "docs:clean": "node scripts/clean-docs.mjs",
    "docs:api": "typedoc --options typedoc.json",
    "docs:graphs": "node scripts/generate-architecture-docs.mjs",
    "docs:all": "npm run docs:clean && npm run docs:api && npm run docs:graphs",
    "check:deps": "npm audit --audit-level=high",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.0.8"
  }
}
